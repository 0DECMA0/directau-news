---
import { getCollection } from 'astro:content';
import '../../styles/global.css'; // ¡Aquí importamos Tailwind!

export async function getStaticPaths() {
  const newsEntries = await getCollection('news');
  return newsEntries.map(entry => ({
    params: { slug: entry.slug }, 
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const formattedDate = new Date(entry.data.date).toLocaleDateString('en-AU', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{entry.data.title} | DirectAU</title>
  </head>
  <body class="bg-slate-50 text-slate-900 font-sans antialiased">
    
    <header class="bg-[#003087] text-white p-5 shadow-md border-b-4 border-red-600">
      <div class="max-w-3xl mx-auto flex justify-between items-center">
        <div class="font-black text-3xl tracking-tighter">
          DirectAU<span class="text-red-500">.news</span>
        </div>
        <div class="text-sm font-semibold tracking-widest text-blue-200">
          LATEST ALERTS
        </div>
      </div>
    </header>

    <main class="max-w-3xl mx-auto px-6 py-12 bg-white shadow-sm mt-6 mb-12 rounded-sm border border-slate-200">
      <p class="text-xs text-slate-500 uppercase tracking-widest mb-4 font-bold">
        Published: {formattedDate}
      </p>

      <h1 class="text-4xl md:text-5xl font-extrabold mb-8 leading-tight text-slate-900">
        {entry.data.title}
      </h1>

      <hr class="mb-8 border-slate-200" />

      <article class="prose prose-lg max-w-none prose-slate prose-headings:font-bold prose-a:text-blue-600 text-lg leading-relaxed">
        <Content />
      </article>

      <div class="mt-16 p-6 bg-amber-50 border-l-4 border-amber-500 rounded-r-md shadow-inner">
        <h3 class="text-amber-800 font-bold text-lg mb-2 flex items-center">
          📱 Zona del Editor (Reels Script)
        </h3>
        <p class="text-amber-700 text-sm mb-4">
          Guion seguro para evitar bloqueos del algoritmo.
        </p>
        <div class="p-4 bg-white border border-amber-200 rounded font-mono text-sm whitespace-pre-wrap text-slate-800">
          {entry.data.reels_script}
        </div>
      </div>
    </main>
  </body>
</html>
