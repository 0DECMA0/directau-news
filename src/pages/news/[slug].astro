---
import { getCollection } from 'astro:content';
import '../../styles/global.css';

export async function getStaticPaths() {
  const newsEntries = await getCollection('news');
  return newsEntries.map(entry => ({
    params: { slug: entry.slug }, 
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const formattedDate = new Date(entry.data.date).toLocaleDateString('en-AU', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

// Calcular tiempo de lectura estimado (200 palabras por minuto)
const wordCount = entry.body ? entry.body.split(/\s+/).length : 0;
const readTime = Math.max(1, Math.ceil(wordCount / 200)); 
---

<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{entry.data.title} | DirectAU.news</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Playfair+Display:ital,wght@0,700;0,900;1,700&display=swap" rel="stylesheet">
  </head>
  
  <body class="bg-slate-50 text-slate-900 font-['Inter'] antialiased min-h-screen flex flex-col dark:bg-slate-950 dark:text-slate-100 transition-colors duration-300">
    
    <header class="bg-[#003087] text-white p-5 shadow-lg border-b-4 border-red-600 sticky top-0 z-50">
      <div class="max-w-6xl mx-auto flex justify-between items-center">
        <a href="/" class="font-black text-3xl tracking-tighter hover:text-blue-100 transition-colors">
          DirectAU<span class="text-red-500">.news</span>
        </a>
        <div class="hidden md:block text-xs font-bold tracking-widest text-blue-200 uppercase">
          Australia's Digital Pulse
        </div>
      </div>
    </header>

    <main class="grow max-w-4xl mx-auto px-4 md:px-0 py-8 w-full">
      
      <a href="/" class="inline-flex items-center text-sm font-bold text-[#003087] dark:text-blue-400 hover:text-red-600 dark:hover:text-red-500 transition-colors mb-8 group">
        <svg class="w-5 h-5 mr-2 transform group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        BACK TO HEADLINES
      </a>

      <article class="bg-white dark:bg-slate-900 shadow-xl rounded-2xl overflow-hidden border border-slate-200 dark:border-slate-800 transition-colors duration-300">
        
        <div class="w-full aspect-video bg-slate-200 dark:bg-slate-800 relative overflow-hidden group">
          <img 
            src={entry.data.image || '/placeholder-news.jpg'} 
            alt={entry.data.title}
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
          />
          <div class="absolute inset-0 bg-linear-to-t from-black/80 via-black/20 to-transparent flex items-end">
            <p class="p-6 text-white text-xs font-bold tracking-widest uppercase flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-red-600 animate-pulse"></span>
              Exclusive Coverage • {formattedDate}
            </p>
          </div>
        </div>

        <div class="p-6 md:p-12">
          <header class="mb-10">
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold font-['Playfair_Display'] mb-6 leading-[1.1] text-slate-900 dark:text-white tracking-tight">
              {entry.data.title}
            </h1>
            
            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 py-4 border-y border-slate-100 dark:border-slate-800">
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-full bg-[#003087] flex items-center justify-center text-white font-black text-sm shadow-md">
                  AI
                </div>
                <div>
                  <p class="text-sm font-bold text-slate-900 dark:text-slate-100">DirectAU AI Reporter</p>
                  <p class="text-xs text-slate-500 dark:text-slate-400">Verified Breaking News • ⏳ {readTime} min read</p>
                </div>
              </div>
              
              <div class="flex items-center gap-2">
                <button aria-label="Share on Twitter" class="p-2 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 hover:bg-[#1DA1F2] hover:text-white transition-colors">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/></svg>
                </button>
                <button aria-label="Share on WhatsApp" class="p-2 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 hover:bg-[#25D366] hover:text-white transition-colors">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                </button>
              </div>
            </div>
          </header>

          <section class="prose prose-xl dark:prose-invert max-w-none prose-slate 
            prose-headings:font-['Playfair_Display'] prose-headings:font-bold
            prose-img:rounded-xl 
            prose-a:text-[#003087] dark:prose-a:text-blue-400 prose-a:no-underline hover:prose-a:underline 
            text-slate-800 dark:text-slate-300 leading-relaxed
            
            prose-blockquote:font-['Playfair_Display'] 
            prose-blockquote:text-3xl md:prose-blockquote:text-4xl 
            prose-blockquote:font-black 
            prose-blockquote:text-slate-900 dark:prose-blockquote:text-white 
            prose-blockquote:border-l-8 
            prose-blockquote:border-red-600 
            prose-blockquote:pl-8 
            prose-blockquote:my-12 
            prose-blockquote:not-italic
            prose-blockquote:leading-tight">
            <Content />
          </section>

          {entry.data.reels_script && (
            <aside class="mt-16 p-8 bg-slate-950 rounded-2xl shadow-2xl relative overflow-hidden group border border-slate-800">
              <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-20 transition-opacity">
                <svg class="w-24 h-24 text-emerald-500/30" fill="currentColor" viewBox="0 0 24 24"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/></svg>
              </div>
              
              <div class="relative z-10">
                <h3 class="text-emerald-400 font-black text-xl mb-4 flex items-center uppercase tracking-tighter">
                  <span class="w-3 h-3 bg-red-500 rounded-full mr-3 animate-pulse"></span>
                  DirectAU Safe-Script™
                </h3>
                <div class="p-6 bg-slate-900 border border-slate-700 rounded-xl font-mono text-sm leading-relaxed text-emerald-50/90 backdrop-blur-sm">
                  {entry.data.reels_script}
                </div>
                <p class="mt-4 text-slate-500 text-xs italic">
                  * SecOps Note: Contenido optimizado para evasión de restricciones algorítmicas (Meta/TikTok).
                </p>
              </div>
            </aside>
          )}
        </div>
      </article>
      
      <footer class="mt-12 text-center text-slate-400 dark:text-slate-500 text-xs pb-12">
        <p>DirectAU.news • Australia Digital Division</p>
        <p class="mt-1">Coded for speed, verified by humans.</p>
      </footer>
    </main>
  </body>
</html>